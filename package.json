{
  "name": "@dcyfr/ai-web",
  "private": true,
  "version": "2.0.0",
  "description": "Production-ready full-stack Next.js web application template with App Router, Drizzle ORM, JWT auth, and Tailwind CSS",
  "author": "DCYFR Labs",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:snapshots": "playwright test e2e/snapshots.spec.ts --project=chromium",
    "test:snapshots:update": "playwright test e2e/snapshots.spec.ts --project=chromium --update-snapshots",
    "examples:compile": "tsc --noEmit",
    "examples:check": "npm run examples:compile",
    "examples:test": "npm run examples:check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "release": "changeset publish"
  },
  "dependencies": {
    "@dcyfr/utils": "file:vendor/dcyfr-utils",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.11.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@vercel/toolbar": "^0.2.2",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^1.0.0-beta.23",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^29.1.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dcyfr-labs/dcyfr-ai-web"
  },
  "bugs": {
    "url": "https://github.com/dcyfr-labs/dcyfr-ai-web/issues"
  },
  "homepage": "https://github.com/dcyfr-labs/dcyfr-ai-web#readme",
  "overrides": {
    "postcss": "^8.5.10",
    "path-to-regexp": "^6.3.0",
    "minimatch": ">=9.0.7"
  }
}
